# ===== Git GUI Tool line ending rules BEGIN =====
# Cross-platform line ending rules for Windows development
* text=auto

# Source code / scripts usually keep LF
*.py text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cs text eol=lf
*.java text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Windows command/project files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.uasset binary
*.umap binary
*.fbx binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.zip binary
*.7z binary
*.rar binary
# ===== Git GUI Tool line ending rules END =====
